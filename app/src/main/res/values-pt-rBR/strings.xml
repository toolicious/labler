    <!-- Additional strings -->
    <string name="about_description">LaBLEr é um app de impressão de etiquetas para impressoras térmicas Bluetooth Low Energy da família Marklife (P15, P12, L13). Crie suas próprias etiquetas direto no celular com texto, símbolos e molduras, salve-as como modelos e imprima novamente quando quiser.</string>
